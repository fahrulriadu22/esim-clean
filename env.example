# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database

# ESIM API Configuration
ESIM_ACCESS_CODE=your_esim_access_code
ESIM_SECRET_KEY=your_esim_secret_key

# Telegram Bot Configuration
BOT_KEY=your_telegram_bot_token

# PayPal Configuration
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# TON (The Open Network) Configuration
NEXT_PUBLIC_TON_RECIPIENT_ADDRESS=your_ton_recipient_address
TON_API_URL=https://toncenter.com

# Upstash Redis Configuration (for rate limiting and caching)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token

# Application Configuration
NEXT_PUBLIC_APP_URL=https://your-app-url.com

# Telegram Stars Configuration
STARS_RATE=100

# Data API Configuration
DATA_API_KEY=your_data_api_key
